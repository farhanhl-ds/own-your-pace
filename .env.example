# ─── Database ───────────────────────────────────────────────
POSTGRES_DB=fitclone
POSTGRES_USER=fitclone
POSTGRES_PASSWORD=changeme_strong_password

# ─── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ─── FastAPI ─────────────────────────────────────────────────
SECRET_KEY=changeme_jwt_secret_min_32_chars
INTERNAL_API_KEY=changeme_n8n_to_api_key
DEBUG=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# ─── Strava OAuth ────────────────────────────────────────────
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_WEBHOOK_VERIFY_TOKEN=changeme_webhook_token

# ─── n8n ─────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_USER=admin
N8N_PASSWORD=changeme_n8n_password

# ─── General ─────────────────────────────────────────────────
TIMEZONE=Asia/Jakarta
